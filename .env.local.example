# Base44 app configuration
VITE_BASE44_APP_ID=your_app_id
VITE_BASE44_APP_BASE_URL=your_backend_url

# Invyra Forecasting Engine API
# Leave blank to keep the Item Details forecast panel in safe unavailable mode.
# Set to the local or deployed forecasting engine API URL to enable live calls.
# Example local value:
# VITE_INVYRA_FORECASTING_API_BASE_URL=http://127.0.0.1:8000
VITE_INVYRA_FORECASTING_API_BASE_URL=
