{
  "name": "ReceivingRecord",
  "type": "object",
  "properties": {
    "po_number": {
      "type": "string"
    },
    "supplier": {
      "type": "string"
    },
    "confirmed_at": {
      "type": "string",
      "format": "date-time"
    },
    "confirmed_by": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Complete",
        "Partial",
        "Discrepancy"
      ],
      "default": "Complete"
    },
    "discrepancy_status": {
      "type": "string",
      "enum": [
        "Flagged",
        "Awaiting Supplier Response",
        "Supplier Responded",
        "Resolution Proposed",
        "Supplier Confirmed",
        "Resolved"
      ],
      "description": "Status of discrepancy resolution flow"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": {
            "type": "string"
          },
          "expected": {
            "type": "number"
          },
          "received": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "discrepancy_reason": {
            "type": "string"
          },
          "discrepancy_note": {
            "type": "string"
          }
        }
      }
    },
    "supplier_responses": {
      "type": "array",
      "description": "Thread of supplier responses to discrepancies",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "warehouse_decision": {
      "type": "string",
      "description": "Warehouse proposal: e.g., 'Accept explanation', 'Credit memo issued', 'Replacement shipment requested'"
    },
    "warehouse_decision_note": {
      "type": "string",
      "description": "Detailed warehouse reasoning"
    },
    "warehouse_decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "supplier_confirmed": {
      "type": "boolean",
      "default": false,
      "description": "Supplier has confirmed agreement with warehouse decision"
    },
    "supplier_confirmed_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time",
      "description": "When both parties agreed and issue was fully resolved"
    }
  },
  "required": [
    "po_number",
    "supplier"
  ]
}